#include <iostream>
#include <locale>
using namespace std;

void sort(int** a, int n)
{
    for (int j = 0; j < n; j++) 
    { 
        for (int i = 0; i < n - 1; i++) 
        {
            int lowindex = i;
            int lowkey = a[i][j];
            for (int k = i + 1; k < n; k++) 
            {
                if (a[k][j] < lowkey) 
                {
                    lowkey = a[k][j];
                    lowindex = k;
                }
            }
            int temp = a[i][j];
            a[i][j] = a[lowindex][j];
            a[lowindex][j] = temp;
        }
    }
}
int main()
{
    setlocale(LC_ALL, "Russian");
    int n;
    cin >> n;
    int **z = new int *[n];
    for(int i = 0; i < n; ++i) z[i] = new int [n];
    for (int i = 0; i < n; ++i)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = ";
            cin >> *(*(z+i)+j);
        }
    cout << "Исходная матрица: " << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    sort(z, n);

    cout << "После сотрировки: " << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    for(int i = 0; i < n; ++i) delete [] z[i];
    delete [] z;
}
