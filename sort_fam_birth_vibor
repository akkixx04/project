#include <iostream>
#include <fstream>
#include <string>
#include <locale>
using namespace std;

struct mas {
    string surname;
    string name;
    string patronymic;
    int birth;
    int grades[5];
};

void sort(mas* a, int n)
{
    int i, j, lowindex;
    mas temp;

    for (i = 0; i < n - 1; i++) 
    {
        lowindex = i;
        for (j = i + 1; j < n; j++) 
        {
            bool smaller = false;

            if (a[j].surname < a[lowindex].surname) 
            {
                smaller = true;
            }
            else if (a[j].surname == a[lowindex].surname) 
            {
                if (a[j].birth < a[lowindex].birth) 
                {
                    smaller = true;
                }
            }

            if (smaller) 
            {
                lowindex = j;
            }
        }
        temp = a[i];
        a[i] = a[lowindex];
        a[lowindex] = temp;
    }
}

