    ofstream out("output.txt");

    int group;
    in >> group;

    mas students[100];
    int n = 0;

    while(in >> students[n].surname >> students[n].name >> students[n].patronymic >> students[n].birth)
    {
        for (int i = 0; i < 5; i++) {
            int grade;
            in >> grade;
            students[n].grades[i] = grade;
        }
        n++;
    }

    sort(students, n);

    out << group << endl;
    for (int i = 0; i < n; i++, out << endl) 
    {
    out << students[i].surname << " " << students[i].name << " " << students[i].patronymic << " " << students[i].birth << " ";
    for (int k = 0; k < 5; k++) 
    {
        out << students[i].grades[k] << " ";
    }
}

    in.close();
    out.close();
}
