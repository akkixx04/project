#include <iostream>
#include <locale>
#include <string>
#include <windows.h>
using namespace std;
int main()
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
    setlocale(LC_ALL, "Russian");
    string text, word;
    cout << "Введите текстовое сообщение: ";
    getline(cin, text);
    cout << "Введите слово: ";
    getline(cin, word);
    int pos = 0;
    while ((pos = text.find(word, pos)) < text.length())
   {
    	pos += word.length();
    	text.insert(pos, "!");
   	pos++;
   }    
   cout << "Результат: " << text;
}
