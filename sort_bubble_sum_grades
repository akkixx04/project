#include <iostream>
#include <fstream>
#include <string>
#include <locale>
using namespace std;

struct mas {
    string surname;
    string name;
    string patronymic;
    int birth;
    int grades[5];
    int key;
};

void sort(mas* a, int n)
{
    mas temp;
    int i, j;
    for (i = 0; i < n - 1; i++)
        for (j = n - 1; j > i; j--)
            if (a[j].key > a[j - 1].key)
            {
                temp = a[j];
                a[j] = a[j - 1];
                a[j - 1] = temp;
            }
}

int main()
{
    setlocale(LC_ALL, "Russian");
    ifstream in("input.txt");
    ofstream out("output.txt");

    int group;
    in >> group;

    mas students[100];
    int n = 0;

    while(in >> students[n].surname >> students[n].name >> students[n].patronymic >> students[n].birth)
    {
        students[n].key = 0;
        for (int i = 0; i < 5; i++) {
            int grade;
            in >> grade;
            students[n].grades[i] = grade;
            students[n].key += grade;
        }
        n++;
    }

    sort(students, n);

    out << group << endl;
    for (int i = 0; i < n; i++) {
        out << students[i].surname << " " << students[i].name << " " << students[i].patronymic << " " << students[i].birth << " " << "Сумма: " << students[i].key << endl;
    }

    in.close();
    out.close();
}
