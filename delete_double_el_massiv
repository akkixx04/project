#include <iostream>
#include <locale>
using namespace std;
int main()
{
    setlocale(LC_ALL, "Russian");
    int n;
    cin >> n;
    int *arr = new int [n];
    for(int i = 0; i < n; i++)
    {
        cout << "arr[" << i << "] = ";
        cin >> *(arr + i);
    }

    int count = 0;
    for (int i = 0; i < n; i++) {
        bool once = true;
        for (int j = 0; j < i; j++) {
            if (arr[j] == arr[i]) {
                once = false; 
                break;
            }
        }
        if (once) {
            count++;
        }
    }

    int *new_arr = new int [count];
    int k = 0;
    
    for (int i = 0; i < n; i++) {
        bool once = true;
        for (int j = 0; j < i; j++) {
            if (arr[j] == arr[i]) {
                once = false; 
                break;
            }
        }
        if (once) {
            new_arr[k] = arr[i];
            k++;
        }
    }

    delete[] arr;

    cout << "Измененный массив: " ;
    for(int i = 0; i < count; i++)
        cout << new_arr[i] << " ";

    delete[] new_arr;
}
