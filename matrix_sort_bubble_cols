#include <iostream>
#include <locale>
using namespace std;

void sort(int** a, int n)
{
    for (int j = 0; j < n; j++) 
    {
        for (int i = 0; i < n - 1; i++) 
        {
            for (int k = 0; k < n - i - 1; k++) 
            {
                if (a[k][j] > a[k + 1][j]) 
                {
                    int temp = a[k][j];
                    a[k][j] = a[k + 1][j];
                    a[k + 1][j] = temp;
                }
            }
        }
    }
}

int main()
{
    setlocale(LC_ALL, "Russian");
    int n;
    cin >> n;
    int **z = new int *[n];
    for(int i = 0; i < n; ++i) z[i] = new int [n];
    for (int i = 0; i < n; ++i)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = ";
            cin >> *(*(z+i)+j);
        }
    cout << "Исходная матрица: " << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    sort(z, n);

    cout << "После сотрировки: " << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    for(int i = 0; i < n; ++i) delete [] z[i];
    delete [] z;
}
