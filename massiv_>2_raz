#include <iostream>
using namespace std;
void main()
{
    int n = 10;
    int a[10] = {1, 2, 3, 3, 1, 5, 3, 2, 2, 10};
    int *b = new int [n];
    int size_b = 0;
    for (int i = 0; i < n; i++)
    {
        int count = 0;
        for (int j = 0; j < n; j++)
        {
            if (a[i] == a[j]) count++;
        }

        if (count <= 2) b[size_b++] = a[i];
    }

    cout << size_b << endl;

    int *p = &b[0];
    for (int x = 0; x < size_b; x++)
        cout << "b[" << x << "] = " << *p++ << endl;

    delete [] b;
}
