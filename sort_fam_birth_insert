#include <iostream>
#include <fstream>
#include <string>
#include <locale>
using namespace std;

struct mas {
    string surname;
    string name;
    string patronymic;
    int birth;
    int grades[5];
};

void sort(mas* a, int n)
{
    for (int i = 1; i < n; i++) 
    {
        mas temp = a[i];
        int j = i - 1;
        while (j >= 0) 
        {
            bool swap = false;
            if (a[j].surname > temp.surname) 
            {
                swap = true;
            }
            else if (a[j].surname == temp.surname) 
            {
                if (a[j].birth < temp.birth) 
                {
                    swap = true;
                }
            }
            if (swap) 
            {
                a[j + 1] = a[j];
                j--;
            } 
            else 
            {
                break;
            }
        }
        a[j + 1] = temp;
    }
}

