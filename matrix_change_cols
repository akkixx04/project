#include <iostream>
#include <locale>
using namespace std;
int main()
{
    setlocale(LC_ALL, "Russian");
    int n;
    cin >> n;
    int **z = new int *[n];
    for(int i = 0; i < n; ++i) z[i] = new int [n];
    for (int i = 0; i < n; ++i)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = ";
            cin >> *(*(z+i)+j);
        }
    cout << "ДО" << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    for (int i = 0; i < n; ++i)
        for (int j = 0; j < n/2; ++j)
        {
            int el = z[i][j];
            z[i][j] = z[i][n - 1 - j];
            z[i][n - 1 - j] = el;
        }

    cout << "ПОСЛЕ" << endl;
    for (int i = 0; i < n; ++i, cout << endl)
        for (int j = 0; j < n; ++j)
        {
            cout << "z[" << i << "][" << j << "] = " << *(*(z+i)+j) << "\t";
        }

    for(int i = 0; i < n; ++i) delete [] z[i];
    delete [] z;
}
